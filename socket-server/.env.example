# Socket.IO Server - Railway Configuration

# Port (Railway sets this automatically)
PORT=3001

# Database (same as main app)
DATABASE_URL=postgresql://user:password@host:5432/mindsp

# CORS - Allowed Origins (Vercel domains)
ALLOWED_ORIGINS=https://your-app.vercel.app,https://your-app-preview.vercel.app

# Node Environment
NODE_ENV=production
