# Supabase
# Get these from: Supabase Dashboard > Settings > API
NEXT_PUBLIC_SUPABASE_URL="https://[PROJECT-REF].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY="your-publishable-key"

# Database (Supabase)
# Get these from: Supabase Dashboard > Settings > Database > Connection string
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres"

# NextAuth
# En production: https://votre-domaine.vercel.app
NEXTAUTH_URL="http://localhost:3000"
# Générer avec: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
NEXTAUTH_SECRET="your-secret-key-here"

# Redis (BullMQ - Required)
REDIS_HOST="localhost"
REDIS_PORT="6379"
REDIS_URL="redis://localhost:6379"

# Upstash Redis (for rate limiting - Required)
UPSTASH_REDIS_REST_URL="https://your-redis-url.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-upstash-token"

# Email (optional for development)
SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_USER="your-email@example.com"
SMTP_PASSWORD="your-password"
SMTP_FROM="noreply@mindsp.fr"

# App Config
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="MindSP"

# Socket.IO Server (Railway en production, local en dev)
# En production: https://votre-socket-server.railway.app
NEXT_PUBLIC_SOCKET_URL="http://localhost:3001"

# CORS - Allowed Origins (comma-separated)
# Utilise par: next.config.js (serverActions), socket-server (Socket.IO CORS)
# En production: listez tous vos domaines (Vercel, custom domain)
# Exemple: https://mindsp.vercel.app,https://mindsp.fr
ALLOWED_ORIGINS="http://localhost:3000"

# Feature Flags
NEXT_PUBLIC_ENABLE_PWA="true"
NEXT_PUBLIC_ENABLE_OFFLINE="true"

# Web Push Notifications (VAPID Keys)
# Generate with: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY="your-vapid-public-key"
VAPID_PRIVATE_KEY="your-vapid-private-key"
VAPID_SUBJECT="mailto:admin@mindsp.fr"

# Node Environment
NODE_ENV="development"

# Logging (optional - default: "info" in production, "debug" in development)
# LOG_LEVEL="info"

# Prisma
PRISMA_HIDE_UPDATE_MESSAGE="true"
