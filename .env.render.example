# ============================================
# RENDER.COM - Variables d'environnement
# ============================================
#
# Ce fichier contient toutes les variables nécessaires pour Render.
# Copiez ces variables dans le Dashboard Render → Environment
#
# NE PAS COMMITER CE FICHIER AVEC VOS VRAIES VALEURS !
# ============================================

# ============================================
# DATABASE (Auto-rempli par Render Blueprint)
# ============================================
# Render remplit automatiquement ces variables depuis votre base PostgreSQL
# DATABASE_URL=postgresql://...
# REDIS_HOST=...
# REDIS_PORT=...
# REDIS_URL=...

# ============================================
# APPLICATION URLS (À définir APRÈS le 1er déploiement)
# ============================================
# Remplacez "votre-app" par votre nom d'app Render
NEXTAUTH_URL=https://votre-app.onrender.com
NEXT_PUBLIC_APP_URL=https://votre-app.onrender.com
ALLOWED_ORIGINS=https://votre-app.onrender.com

# ============================================
# NEXTAUTH (Auto-généré par Render)
# ============================================
# Render génère automatiquement un secret sécurisé
# NEXTAUTH_SECRET=xxx (généré automatiquement)

# ============================================
# UPSTASH REDIS (Obligatoire - À créer sur upstash.com)
# ============================================
# 1. Allez sur https://upstash.com
# 2. Créez un compte gratuit
# 3. Créez une base Redis
# 4. Copiez les credentials ici
UPSTASH_REDIS_REST_URL=https://xxxxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=AYTgA_xxxxx

# ============================================
# WEB PUSH NOTIFICATIONS (Obligatoire - À générer)
# ============================================
# Générez ces clés avec : npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=BEg4F_xxxxx
VAPID_PRIVATE_KEY=abc789_xxxxx
VAPID_SUBJECT=mailto:admin@mindsp.fr

# ============================================
# NODE ENVIRONMENT (Géré par Render)
# ============================================
NODE_ENV=production
PORT=10000
PRISMA_HIDE_UPDATE_MESSAGE=true

# ============================================
# APP CONFIG (Optionnel)
# ============================================
NEXT_PUBLIC_APP_NAME=MindSP
NEXT_PUBLIC_ENABLE_PWA=true
NEXT_PUBLIC_ENABLE_OFFLINE=true

# ============================================
# EMAIL (Optionnel - Pour plus tard)
# ============================================
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=your-email@example.com
# SMTP_PASSWORD=your-password
# SMTP_FROM=noreply@mindsp.fr

# ============================================
# UPLOADTHING (Optionnel - Pour uploads fichiers)
# ============================================
# UPLOADTHING_SECRET=sk_live_xxxxx
# UPLOADTHING_APP_ID=xxxxx

# ============================================
# SENTRY (Optionnel - Pour monitoring)
# ============================================
# SENTRY_DSN=https://xxxxx@sentry.io/xxxxx
# NEXT_PUBLIC_SENTRY_DSN=https://xxxxx@sentry.io/xxxxx

# ============================================
# NOTES IMPORTANTES
# ============================================
#
# Variables AUTO-REMPLIES par Render (ne pas définir):
# - DATABASE_URL
# - REDIS_HOST
# - REDIS_PORT
# - REDIS_URL
# - NEXTAUTH_SECRET
#
# Variables À DÉFINIR MAINTENANT:
# - UPSTASH_REDIS_REST_URL
# - UPSTASH_REDIS_REST_TOKEN
# - NEXT_PUBLIC_VAPID_PUBLIC_KEY
# - VAPID_PRIVATE_KEY
#
# Variables À DÉFINIR APRÈS 1ER DÉPLOIEMENT:
# - NEXTAUTH_URL (avec URL Render)
# - NEXT_PUBLIC_APP_URL (avec URL Render)
# - ALLOWED_ORIGINS (avec URL Render)
#
# ============================================
# COMMANDES UTILES
# ============================================
#
# Générer VAPID keys:
# $ npx web-push generate-vapid-keys
#
# Générer NEXTAUTH_SECRET (si besoin manuel):
# $ openssl rand -base64 32
#
# Tester health check:
# $ curl https://votre-app.onrender.com/api/health
#
# ============================================
